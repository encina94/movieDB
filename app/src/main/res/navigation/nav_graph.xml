<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@+id/moviesList">

    <fragment
        android:id="@+id/moviesList"
        android:name="com.brubank.movies.views.MoviesListFragment"
        android:label="MoviesList"
        tools:layout="@layout/fragment_movies_list">
        <action
            android:id="@+id/action_movie_detail"
            app:destination="@+id/movieDetail"
            />
    </fragment>
    <fragment
        android:id="@+id/movieDetail"
        android:name="com.brubank.movies.views.MovieDetailFragment"
        android:label="MovieDetail"
        tools:layout="@layout/fragment_movie_detail">
    </fragment>

</navigation>